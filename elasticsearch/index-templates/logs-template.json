{
  "index_patterns": ["logs-*"] ,
  "template": {
    "settings": {"number_of_shards": 1},
    "mappings": {
      "properties": {
        "timestamp": {"type": "date"},
        "service_name": {"type": "keyword"},
        "environment": {"type": "keyword"},
        "log_level": {"type": "keyword"},
        "request_id": {"type": "keyword"},
        "correlation_id": {"type": "keyword"},
        "event_type": {"type": "keyword"}
      }
    }
  }
}
