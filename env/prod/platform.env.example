ENVIRONMENT=prod
COMPOSE_PROJECT_NAME=entregamais-prod
BACKEND_IMAGE=registry.example.com/entregamais/backend:1.0.0
FRONTEND_IMAGE=registry.example.com/entregamais/frontend:1.0.0
FISCAL_IMAGE=registry.example.com/entregamais/fiscal:1.0.0

# IMPORTANT: replace all values before use
KEYCLOAK_ADMIN=CHANGE_ME
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME
KEYCLOAK_PUBLIC_URL=https://keycloak.example.com
KEYCLOAK_FISCAL_CLIENT_SECRET=CHANGE_ME
KEYCLOAK_DOLIBARR_CLIENT_SECRET=CHANGE_ME
POSTGRES_DB=entregamais
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_AUTH_DB=keycloak
POSTGRES_AUTH_USER=CHANGE_ME
POSTGRES_AUTH_PASSWORD=CHANGE_ME
DOLIBARR_DB_NAME=dolibarr
DOLIBARR_DB_USER=CHANGE_ME
DOLIBARR_DB_PASSWORD=CHANGE_ME
DOLIBARR_DB_ROOT_PASSWORD=CHANGE_ME
DOLIBARR_PUBLIC_URL=https://dolibarr.example.com
DOLIBARR_ADMIN_LOGIN=admin@example.com
DOLIBARR_ADMIN_PASSWORD=CHANGE_ME
DOLIBARR_COMPANY_NAME=EntregaMais Fiscal
FISCAL_PUBLIC_URL=https://fiscal.example.com
FISCAL_SESSION_SECRET=CHANGE_ME
FISCAL_API_TOKEN=CHANGE_ME
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME
RABBITMQ_DEFAULT_USER=CHANGE_ME
RABBITMQ_DEFAULT_PASS=CHANGE_ME
